---
import { siteConfig } from '../config';
import ContactButtons from './ContactButtons.astro';
---

<header class="site-header">
  <a href="/" class="site-name">{siteConfig.name}</a>

  <button
    id="nav-toggle"
    class="nav-toggle"
    aria-label="Toggle navigation"
    aria-expanded="false"
    aria-controls="site-nav"
  >
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>

  <nav id="site-nav" class="site-nav">
    <ul>
      {siteConfig.nav.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <div class="nav-contact">
      <ContactButtons />
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen ?? false));
  });
</script>

<style>
  .site-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: var(--space-sm) var(--space-lg);
    border-bottom: 4px double var(--color-gold);
  }

  .site-name {
    text-decoration: none;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    color: var(--color-text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-right: auto;
  }

  /* ── Hamburger button ── */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
    color: var(--color-gold);
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-gold);
  }

  /* ── Mobile nav ── */
  @media (max-width: 767px) {
    .site-nav {
      display: none;
      width: 100%;
    }

    .site-nav.is-open {
      display: block;
    }

    .site-nav ul {
      padding: var(--space-sm) 0;
      border-top: 1px solid var(--color-gold);
      margin-top: var(--space-sm);
    }

    .site-nav li {
      padding: var(--space-xs) 0;
    }

    .site-nav a {
      font-family: var(--font-body);
      font-weight: bold;
      font-size: var(--font-size-sm);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      text-decoration: none;
      color: var(--color-text);
    }

    .nav-contact {
      padding: var(--space-sm) 0;
      border-top: 1px solid var(--color-gold);
      margin-top: var(--space-sm);
      display: flex;
      justify-content: flex-start;
    }
  }

  /* ── Desktop nav ── */
  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }

    .site-nav {
      display: flex;
      align-items: center;
    }

    .site-nav ul {
      display: flex;
      gap: var(--space-md);
    }

    .site-nav a {
      font-family: var(--font-body);
      font-weight: bold;
      font-size: var(--font-size-sm);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      text-decoration: none;
      color: var(--color-text);
      border: 2px double transparent;
      padding: var(--space-xs) var(--space-sm);
      transition: all steps(4) 0.15s;
    }

    .site-nav a:hover {
      border-color: var(--color-gold);
      color: var(--color-gold);
    }

    .nav-contact {
      display: flex;
      align-items: center;
      border-left: 1px solid var(--color-gold);
      padding-left: var(--space-md);
      margin-left: var(--space-sm);
    }
  }
</style>
