---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrengthsFlow from '../components/strengths/StrengthsFlow';
import { wordlist } from '../data/wordlist';
import '../styles/strengths.css';
import '../styles/strengths-theme.css';
---

<BaseLayout
  title="Strengths Identifier"
  description="Discover your core strengths through an instinct-driven word selection exercise."
  bodyClass="strengths-page"
>
  <StrengthsFlow words={wordlist} client:load />
</BaseLayout>
