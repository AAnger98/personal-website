---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import DecoBorder from '../components/DecoBorder.astro';
import AsciiDivider from '../components/AsciiDivider.astro';
import { siteConfig } from '../config';
---

<BaseLayout title="Home" description="Adam Angerami — operations and strategy executive. Former Army Major, startup operator, Cornell MBA. Available for senior executive roles.">
  <section class="home-hero">
    <PageTitle title="Adam Angerami" />

    <p class="home-tagline">
      Business Operations Leader.
    </p>

    <AsciiDivider />

    <DecoBorder>
      <p class="home-intro">
        Former U.S. Army Major. First Head of Operations at a $1 billion startup. Now looking for the next hard problem.
      </p>
      <p class="home-intro">
        I build the operating systems that help organizations scale — the team structures, process frameworks, and data infrastructure that turn growth from chaotic into sustainable.
      </p>
      <a href={`mailto:${siteConfig.contact.email}`} class="cta-link">Get in touch ›</a>
    </DecoBorder>
  </section>
</BaseLayout>

<style>
  .home-hero {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    text-align: center;
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    text-transform: uppercase;
    letter-spacing: 0.38em;
    color: var(--color-gold);
    margin-bottom: var(--space-lg);
  }

  .home-intro {
    font-size: var(--font-size-base);
    line-height: var(--line-height-base);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .cta-link {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: bold;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    border: 2px double var(--color-gold);
    padding: var(--space-sm) var(--space-lg);
    text-decoration: none;
    transition: all steps(4) 0.15s;
  }

  .cta-link:hover {
    background: var(--color-gold);
    color: var(--color-bg);
  }
</style>
